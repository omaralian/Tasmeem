{
  "name": "tasmeem",
  "version": "0.1.0",
  "description": "A simple, lightweight CSS framework.",
  "license": "MIT",
  "main": "dist/tasmeem.css",
  "style": "dist/tasmeem.css",
  "files": [
    "dist",
    "src/css"
  ],
  "exports": {
    ".": "./dist/tasmeem.css",
    "./min": "./dist/tasmeem.min.css",
    "./css/*": "./src/css/*"
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "serve": "webpack serve --mode development --open"
  },
  "keywords": [
    "css",
    "framework",
    "tasmeem"
  ],
  "devDependencies": {
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.0",
    "mini-css-extract-plugin": "^2.9.2",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  }
}
